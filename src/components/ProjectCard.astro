---
import type { CollectionEntry } from 'astro:content';

type Props = {
  entry: CollectionEntry<'projects'> | CollectionEntry<'skills'>;
  kind: 'project' | 'skill';
};

const { entry, kind } = Astro.props;
const { name, description, stars, language, tags, logo } = entry.data;
const slug = entry.slug;
const href = kind === 'project' ? `/projects/${slug}/` : `/skills/${slug}/`;
const initial = name.slice(0, 1).toUpperCase();
---

<article
  class="group flex h-full flex-col rounded-2xl border border-surface-border bg-surface-card p-5 shadow-card transition hover:-translate-y-0.5 hover:border-accent/40"
>
  <a href={href} class="flex flex-1 flex-col no-underline">
    <div class="flex items-start gap-3">
      <div
        class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-xl bg-surface text-lg font-semibold text-ink ring-1 ring-surface-border"
      >
        {
          logo ? (
            <img src={logo} alt="" class="h-full w-full object-cover" loading="lazy" width="48" height="48" />
          ) : (
            <span>{initial}</span>
          )
        }
      </div>
      <div class="min-w-0 flex-1">
        <h3 class="font-display text-base font-semibold tracking-tight text-ink group-hover:text-accent">
          {name}
        </h3>
        <p class="mt-1 line-clamp-2 text-sm text-ink-muted">{description}</p>
      </div>
    </div>
    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-ink-muted">
      <span class="rounded-full bg-surface px-2 py-0.5 font-medium text-ink">★ {stars.toLocaleString()}</span>
      <span class="rounded-full bg-surface px-2 py-0.5">{language}</span>
      {
        kind === 'skill' && 'skill_type' in entry.data && (
          <span class="rounded-full bg-accent-soft px-2 py-0.5 text-accent">
            {(entry.data as { skill_type: string }).skill_type}
          </span>
        )
      }
    </div>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.slice(0, 4).map((tag) => (
            <span class="rounded-md bg-surface px-2 py-0.5 text-[11px] text-ink-muted">{tag}</span>
          ))}
        </div>
      )
    }
  </a>
</article>
