---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SEO_TOPICS } from '../../../data/seo-topics';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Trending topics',
  description: 'Topic hubs aligned with high-intent GitHub-related searches.',
  url: new URL('/en/topics/', Astro.site ?? Astro.url.origin).href,
};
---

<BaseLayout
  title="Trending topics | GitHub Hot"
  description="Topic hubs for OpenClaw, Claude Code, agent browser, Vercel skills, and related GitHub trends."
  canonicalPath="/en/topics/"
  lang="en"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="text-sm text-ink-muted">
      <a href="/en/" class="text-ink-muted no-underline hover:text-accent">English home</a>
      <span class="mx-2">/</span>
      <span class="text-ink">Topics</span>
    </nav>
    <h1 class="mt-4 font-display text-3xl font-semibold text-ink">Trending topics</h1>
    <p class="mt-2 max-w-2xl text-ink-muted">
      Each page aggregates curated entries by tags and <code class="text-xs">seo_aliases</code>. Third-party index; see
      individual repos for authoritative docs.
    </p>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        SEO_TOPICS.map((t) => (
          <li>
            <a
              href={`/en/topics/${t.slug}/`}
              class="block rounded-2xl border border-surface-border bg-surface-card p-5 shadow-card no-underline transition hover:border-accent/40"
            >
              <span class="font-display text-lg font-semibold text-ink">{t.h1En}</span>
              <p class="mt-2 line-clamp-2 text-sm text-ink-muted">{t.metaDescriptionEn}</p>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="mt-10 text-sm">
      <a href="/topics/" class="text-accent no-underline">中文话题索引</a>
    </p>
  </div>
</BaseLayout>
