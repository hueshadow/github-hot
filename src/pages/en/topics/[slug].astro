---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { SEO_TOPICS, entryMatchesTopic, type SeoTopic } from '../../../data/seo-topics';

export function getStaticPaths() {
  return SEO_TOPICS.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props as { topic: SeoTopic };

const projects = await getCollection('projects');
const skills = await getCollection('skills');

type Row = { entry: (typeof projects)[0] | (typeof skills)[0]; kind: 'project' | 'skill' };
const rows: Row[] = [];

for (const p of projects) {
  if (entryMatchesTopic(p.data.tags, p.data.seo_aliases, topic)) {
    rows.push({ entry: p, kind: 'project' });
  }
}
for (const s of skills) {
  if (entryMatchesTopic(s.data.tags, s.data.seo_aliases, topic)) {
    rows.push({ entry: s, kind: 'skill' });
  }
}

rows.sort((a, b) => b.entry.data.stars - a.entry.data.stars);

const origin = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const canonicalPath = `/en/topics/${topic.slug}/`;
const zhPath = `/topics/${topic.slug}/`;

const itemListElements = rows.map((r, i) => {
  const path = r.kind === 'project' ? `/projects/${r.entry.slug}/` : `/skills/${r.entry.slug}/`;
  return {
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(path, origin + '/').href,
    name: r.entry.data.name,
  };
});

const jsonLd: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: topic.h1En,
    description: topic.metaDescriptionEn,
    url: new URL(canonicalPath, origin + '/').href,
    inLanguage: 'en',
    mainEntity: {
      '@type': 'ItemList',
      name: topic.h1En,
      numberOfItems: rows.length,
      itemListElement: itemListElements,
    },
  },
];
---

<BaseLayout
  title={topic.pageTitleEn}
  description={topic.metaDescriptionEn}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  lang="en"
  ogType="article"
  articlePublishedTime={new Date().toISOString()}
  hreflangZhPath={zhPath}
  hreflangEnPath={canonicalPath}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="text-sm text-ink-muted">
      <a href="/en/" class="text-ink-muted no-underline hover:text-accent">English home</a>
      <span class="mx-2">/</span>
      <a href="/en/topics/" class="text-ink-muted no-underline hover:text-accent">Topics</a>
      <span class="mx-2">/</span>
      <span class="text-ink">{topic.h1En}</span>
    </nav>

    <h1 class="mt-4 font-display text-3xl font-semibold tracking-tight text-ink">{topic.h1En}</h1>
    <div class="prose-github mt-6 max-w-3xl" set:html={topic.introHtmlEn} />

    <p class="mt-6 text-sm text-ink-muted">
      <strong class="text-ink">{rows.length}</strong> matching entries (by stars).{' '}
      <a href="/projects/">All projects</a> · <a href="/skills/">Skills</a> · <a href="/search/">Search</a> ·{' '}
      <a href={zhPath}>中文版此话题</a>
    </p>

    {
      rows.length > 0 ? (
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {rows.map((r) => (
            <ProjectCard entry={r.entry} kind={r.kind} />
          ))}
        </div>
      ) : (
        <p class="mt-10 rounded-2xl border border-dashed border-surface-border bg-surface-card p-8 text-center text-ink-muted">
          No matching entries yet. Submit repos via our recommendation issue template and add appropriate tags and{' '}
          <code class="text-xs">seo_aliases</code>.
        </p>
      )
    }
  </div>
</BaseLayout>
