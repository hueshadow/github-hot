---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { getRelatedEntries } from '../../utils/related';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allProjects = await getCollection('projects');
const allSkills = await getCollection('skills');
const related = getRelatedEntries(entry, allProjects, allSkills, 6);

const d = entry.data;
const pageSlug = entry.slug;
const canonicalPath = `/projects/${pageSlug}/`;
const metaTitle = d.seo_title ?? `${d.name} — 开源项目 | GitHub Hot`;
const metaDesc = d.seo_description ?? d.description;
const pageUrl = new URL(canonicalPath, Astro.site ?? Astro.url.origin).href;
const originBase = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${originBase}/` },
    { '@type': 'ListItem', position: 2, name: '开源项目', item: `${originBase}/projects/` },
    { '@type': 'ListItem', position: 3, name: d.name, item: pageUrl },
  ],
};
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: d.name,
  description: metaDesc,
  codeRepository: d.repo_url,
  programmingLanguage: d.language,
  url: pageUrl,
};
---

<BaseLayout
  title={metaTitle}
  description={metaDesc}
  canonicalPath={canonicalPath}
  ogImage={d.logo}
  jsonLd={[breadcrumbLd, softwareLd]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="text-sm text-ink-muted">
      <a href="/projects/" class="text-ink-muted no-underline hover:text-accent">项目</a>
      <span class="mx-2">/</span>
      <span class="text-ink">{d.name}</span>
    </nav>

    <header class="mt-6 flex flex-col gap-6 lg:flex-row lg:items-start">
      <div class="flex min-w-0 flex-1 gap-4">
        <div
          class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-surface text-2xl font-semibold text-ink ring-1 ring-surface-border"
        >
          {
            d.logo ? (
              <img src={d.logo} alt="" class="h-full w-full object-cover" loading="eager" width="64" height="64" />
            ) : (
              <span>{d.name.slice(0, 1).toUpperCase()}</span>
            )
          }
        </div>
        <div class="min-w-0">
          <h1 class="font-display text-3xl font-semibold tracking-tight text-ink">{d.name}</h1>
          <p class="mt-2 text-ink-muted">{d.description}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="rounded-full bg-surface px-3 py-1 text-xs font-medium text-ink">{d.category}</span>
            {
              d.tags.map((tag) => (
                <a
                  href={`/tags/${encodeURIComponent(tag)}/`}
                  class="rounded-full bg-surface px-3 py-1 text-xs font-medium text-ink-muted no-underline hover:bg-accent-soft hover:text-accent"
                >
                  {tag}
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <aside
        class="w-full shrink-0 rounded-2xl border border-surface-border bg-surface-card p-5 shadow-card lg:max-w-sm"
      >
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-muted">仓库数据</h2>
        <dl class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">Stars</dt>
            <dd class="font-medium text-ink">{d.stars.toLocaleString()}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">Forks</dt>
            <dd class="font-medium text-ink">{d.forks.toLocaleString()}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">语言</dt>
            <dd class="font-medium text-ink">{d.language}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">最近更新</dt>
            <dd class="font-medium text-ink">{d.last_updated}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">收录时间</dt>
            <dd class="font-medium text-ink">{d.added_at.toISOString().slice(0, 10)}</dd>
          </div>
        </dl>
        <div class="mt-5 flex flex-col gap-2">
          <a
            href={d.repo_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-xl bg-github px-4 py-2.5 text-center text-sm font-semibold text-white no-underline hover:opacity-95 dark:ring-1 dark:ring-white/15"
            >在 GitHub 打开</a
          >
          {
            d.homepage && (
              <a
                href={d.homepage}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-xl border border-surface-border bg-surface px-4 py-2.5 text-center text-sm font-semibold text-ink no-underline hover:border-accent/40"
              >
                官网
              </a>
            )
          }
          {
            d.docs_url && (
              <a
                href={d.docs_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-xl border border-surface-border bg-surface px-4 py-2.5 text-center text-sm font-semibold text-ink no-underline hover:border-accent/40"
              >
                文档
              </a>
            )
          }
        </div>
        <a
          href={`/category/${d.category_slug}/`}
          class="mt-4 inline-block text-sm font-medium text-accent no-underline">同分类条目 →</a
        >
      </aside>
    </header>

    <article class="prose-github mt-12 border-t border-surface-border pt-10">
      <Content />
    </article>

    {
      related.length > 0 && (
        <section class="mt-16 border-t border-surface-border pt-12">
          <h2 class="font-display text-xl font-semibold text-ink">相关推荐</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => (
              <ProjectCard entry={r.entry} kind={r.kind} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
