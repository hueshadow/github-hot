---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { getRelatedEntries } from '../../utils/related';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allProjects = await getCollection('projects');
const allSkills = await getCollection('skills');
const related = getRelatedEntries(entry, allProjects, allSkills, 6);

const d = entry.data;
const pageSlug = entry.slug;
const canonicalPath = `/skills/${pageSlug}/`;
const skillData = d as typeof d & {
  compatible_with: string[];
  install_command?: string;
  skill_type: string;
};
const metaTitle = skillData.seo_title ?? `${skillData.name} — Skill | GitHub Hot`;
const metaDesc = skillData.seo_description ?? skillData.description;
const pageUrl = new URL(canonicalPath, Astro.site ?? Astro.url.origin).href;
const originBase = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${originBase}/` },
    { '@type': 'ListItem', position: 2, name: 'Skills', item: `${originBase}/skills/` },
    { '@type': 'ListItem', position: 3, name: skillData.name, item: pageUrl },
  ],
};
const pageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: skillData.name,
  description: metaDesc,
  url: pageUrl,
};
---

<BaseLayout
  title={metaTitle}
  description={metaDesc}
  canonicalPath={canonicalPath}
  ogImage={skillData.logo}
  jsonLd={[breadcrumbLd, pageLd]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="text-sm text-ink-muted">
      <a href="/skills/" class="text-ink-muted no-underline hover:text-accent">Skills</a>
      <span class="mx-2">/</span>
      <span class="text-ink">{skillData.name}</span>
    </nav>

    <header class="mt-6 flex flex-col gap-6 lg:flex-row lg:items-start">
      <div class="flex min-w-0 flex-1 gap-4">
        <div
          class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-accent-soft text-2xl font-semibold text-accent ring-1 ring-surface-border"
        >
          {
            skillData.logo ? (
              <img
                src={skillData.logo}
                alt=""
                class="h-full w-full object-cover"
                loading="eager"
                width="64"
                height="64"
              />
            ) : (
              <span>{skillData.name.slice(0, 1).toUpperCase()}</span>
            )
          }
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wide text-accent">Skill · {skillData.skill_type}</p>
          <h1 class="mt-1 font-display text-3xl font-semibold tracking-tight text-ink">{skillData.name}</h1>
          <p class="mt-2 text-ink-muted">{skillData.description}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="rounded-full bg-surface px-3 py-1 text-xs font-medium text-ink">{skillData.category}</span>
            {
              skillData.tags.map((tag) => (
                <a
                  href={`/tags/${encodeURIComponent(tag)}/`}
                  class="rounded-full bg-surface px-3 py-1 text-xs font-medium text-ink-muted no-underline hover:bg-accent-soft hover:text-accent"
                >
                  {tag}
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <aside
        class="w-full shrink-0 rounded-2xl border border-surface-border bg-surface-card p-5 shadow-card lg:max-w-sm"
      >
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-muted">兼容与安装</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="text-ink-muted">兼容平台</dt>
            <dd class="mt-1 font-medium text-ink">
              {skillData.compatible_with.length ? skillData.compatible_with.join(' · ') : '—'}
            </dd>
          </div>
          {
            skillData.install_command && (
              <div>
                <dt class="text-ink-muted">安装 / 使用</dt>
                <dd class="mt-1">
                  <code class="block whitespace-pre-wrap break-all rounded-lg bg-surface p-2 text-xs text-ink">
                    {skillData.install_command}
                  </code>
                </dd>
              </div>
            )
          }
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">Stars</dt>
            <dd class="font-medium text-ink">{skillData.stars.toLocaleString()}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">语言</dt>
            <dd class="font-medium text-ink">{skillData.language}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-muted">最近更新</dt>
            <dd class="font-medium text-ink">{skillData.last_updated}</dd>
          </div>
        </dl>
        <div class="mt-5 flex flex-col gap-2">
          <a
            href={skillData.repo_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-xl bg-github px-4 py-2.5 text-center text-sm font-semibold text-white no-underline hover:opacity-95 dark:ring-1 dark:ring-white/15"
            >仓库链接</a
          >
        </div>
        <a
          href={`/category/${skillData.category_slug}/`}
          class="mt-4 inline-block text-sm font-medium text-accent no-underline">同分类条目 →</a
        >
      </aside>
    </header>

    <article class="prose-github mt-12 border-t border-surface-border pt-10">
      <Content />
    </article>

    {
      related.length > 0 && (
        <section class="mt-16 border-t border-surface-border pt-12">
          <h2 class="font-display text-xl font-semibold text-ink">相关推荐</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => (
              <ProjectCard entry={r.entry} kind={r.kind} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
