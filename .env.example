# 构建时写入 astro.config 的 site（sitemap、canonical 等）。Cloudflare Pages 可在项目环境变量中配置同名变量。
PUBLIC_SITE_URL=https://your-domain.pages.dev

# 导航「推荐收录」指向的仓库（owner/repo）。不设则隐藏该链接，关于页会提示如何配置。
# PUBLIC_GITHUB_REPO=your-username/github_hot

# 本地运行 scripts/sync-github.mjs 时可选，提高 GitHub API 限额
# GITHUB_TOKEN=ghp_xxx
